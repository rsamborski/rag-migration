# GCP Configuration
# PROJECT_ID and LOCATION are the primary configuration for the UI.
# If not set, the app will fall back to GOOGLE_CLOUD_PROJECT/LOCATION.
PROJECT_ID=your-project-id
LOCATION=europe-central2

# AlloyDB Configuration
# When running locally, use the AlloyDB Auth Proxy on these ports
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=rag_migration
DB_HOST=127.0.0.1
DB_PORT=5432

# Vertex AI Model
EMBEDDING_MODEL=text-embedding-005

# Gemini Multilingual Model Configuration
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSION=768
